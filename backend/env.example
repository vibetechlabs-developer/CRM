# Copy this file to `backend/.env` (do not commit `.env`) and fill in real values.

# Django
DJANGO_ENV=development
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me-in-dev
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_DB=crm_policy_db
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# CORS
# For development you can set CORS_ALLOW_ALL_ORIGINS=1
# For production, keep it off and explicitly list allowed origins:
CORS_ALLOW_ALL_ORIGINS=1
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
